# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# ── Required for Telegram alerts ─────────────────────────────────────────────
TELEGRAM_TOKEN=your-bot-token-here

# ── Voice recognizer (Whisper) ────────────────────────────────────────────────
# WHISPER_MODEL=base          # tiny | base | small | medium | large
# WHISPER_LANG=               # force a language code (en, fr, ar); blank = auto

# ── LLM Coordinator Agent (local via Ollama) ──────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ── Automation / orchestration (n8n, Make) ────────────────────────────────────
# When a coordinator decision reaches ESCALATE_SEVERITIES, it is POSTed here.
# INCIDENT_WEBHOOK_URL=https://your-n8n-host/webhook/campus-incident
# ESCALATE_SEVERITIES=high     # comma-separated, e.g. "medium,high"

# ── Optional path overrides ───────────────────────────────────────────────────
# Uncomment and edit if your dataset or data directories are outside the project root.

# ECE_DATASET_ROOT=/path/to/ece_campus/dataset
# PROJECT_DATA_ROOT=/path/to/runtime_outputs
# DETECTIONS_ROOT=/path/to/detections
# CROPS_ROOT=/path/to/crops
# FEATURES_ROOT=/path/to/features
# SCORES_ROOT=/path/to/scores
# PROMPTS_DIR=/path/to/prompts

# --- Email alert action (optional) ---
# Gmail needs an App Password (Google Account > Security > 2-Step > App passwords)
EMAIL_TO=dhia.rekik11@gmail.com
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_SEVERITIES=low,medium,high

# --- WhatsApp alert action (optional, via free CallMeBot) ---
# 1) Add +34 644 51 95 23 to contacts  2) WhatsApp it "I allow callmebot to send me messages"
# 3) Put your number + the key it replies with below
WHATSAPP_PHONE=+33XXXXXXXXX
CALLMEBOT_APIKEY=your-callmebot-key
WHATSAPP_SEVERITIES=low,medium,high
